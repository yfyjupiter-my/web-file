# Shared password for the site gate (prd.md §4).
# Replace before deploying — the app refuses to authenticate while this is
# still the placeholder, and refuses to boot in production (SEC-3).
SITE_PASSWORD=REPLACE_ME_BEFORE_DEPLOY

# Secret used to sign session cookies (SEC-1). MUST be set — the app refuses to
# issue or verify sessions without it. Use a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# Supabase — the runtime client (lib/supabase.ts) talks to the REST API, so
# SUPABASE_URL must be the project API URL, NOT a Postgres connection string:
#   https://<project-ref>.supabase.co
# When both are set, getFilesRepo() uses SupabaseFilesRepo; otherwise the
# in-memory mock. Schema/RLS: supabase/migrations/0001_files.sql (npm run migrate).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres (pooler) connection — used ONLY by `npm run migrate` to run
# DDL (scripts/migrate.mjs), never at runtime. From Supabase → Project Settings
# → Database → Connection string (URI). Leave unset if not running migrations.
SUPABASE_DB_URL=
