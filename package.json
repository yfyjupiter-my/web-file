    "cleanup:orphans": "node --env-file=.env.local scripts/cleanup-orphans.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "pg": "^8.22.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
